pipeline {
    agent any

    environment {
        FRONTEND_DIR = 'client'
        ARTIFACT_DIR = 'frontend-artifact'
        DOCKER_IMAGE = 'veeraprasadkoduri/flipkart-frontend:latest'
        DOCKERHUB_CREDENTIALS = 'dockerhub-creds'
    }

    stages {
        stage('Clean Workspace') {
            steps { deleteDir() }
        }

        stage('Clone Repo') {
            steps {
                git url: 'https://github.com/veeraprasadkoduri-cmd/Flipkart_app.git', branch: 'main'
            }
        }

        stage('Install Frontend Dependencies') {
            steps {
                dir("${FRONTEND_DIR}") {
                    sh 'npm install'
                }
            }
        }

        stage('Build Frontend') {
            steps {
                dir("${FRONTEND_DIR}") {
                    sh 'CI=false npm run build'
                }
                sh "rm -rf ${ARTIFACT_DIR} && mkdir ${ARTIFACT_DIR}"
                sh "cp -r ${FRONTEND_DIR}/build/* ${ARTIFACT_DIR}/"
            }
        }

        stage('Archive Artifact') {
            steps {
                archiveArtifacts artifacts: "${ARTIFACT_DIR}/**", fingerprint: true
            }
        }

        stage('Build Docker Image') {
            steps {
                sh "docker build -t ${DOCKER_IMAGE} ."
            }
        }

        stage('Login to Docker Hub') {
            steps {
                withCredentials([usernamePassword(credentialsId: "${DOCKERHUB_CREDENTIALS}", usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                    sh 'echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin'
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                sh "docker push ${DOCKER_IMAGE}"
            }
        }

        stage('Run Docker Container') {
            steps {
                sh "docker rm -f flipkart-frontend || true"
                sh "docker run -d --name flipkart-frontend -p 80:80 ${DOCKER_IMAGE}"
            }
        }
    }

    post {
        success { echo 'Frontend Docker container is running on port 80!' }
        failure { echo 'Pipeline failed. Check logs!' }
    }
}
