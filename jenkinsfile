pipeline {
    agent any

    environment {
        IMAGE_NAME = 'flipkart-frontend'
        IMAGE_TAG  = 'latest'
        CONTAINER_PORT = '72'
    }

    stages {

        stage('Checkout Code') {
            steps {
                git url: 'https://github.com/veeraprasadkoduri-cmd/Flipkart_app.git', branch: 'main'
            }
        }

        stage('Clean Workspace') {
            steps {
                echo "Cleaning workspace..."
                deleteDir()
            }
        }

        stage('Install Frontend Dependencies') {
            steps {
                dir('client') {
                    sh 'npm install'
                }
            }
        }

        stage('Build Frontend') {
            steps {
                dir('client') {
                    sh '''
                        CI=false npm run build
                    '''
                }
            }
        }

        stage('Prepare Artifact') {
            steps {
                sh '''
                    rm -rf frontend-artifact
                    mkdir frontend-artifact
                    cp -r client/build/* frontend-artifact/
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
            }
        }

        stage('Run Docker Container') {
            steps {
                sh '''
                    docker stop ${IMAGE_NAME} || true
                    docker rm ${IMAGE_NAME} || true
                    docker run -d -p ${CONTAINER_PORT}:80 --name ${IMAGE_NAME} ${IMAGE_NAME}:${IMAGE_TAG}
                '''
            }
        }

    }

    post {
        success {
            echo "✅ Flipkart Frontend pipeline completed successfully!"
        }

        failure {
            echo "❌ Pipeline failed! Check logs for errors."
        }
    }
}
